{
  "AllowedHosts": "*",

  "CiCd": {
    "Audience": "openshock-repository-server",
    "RepositoryOwner": "OpenShock"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Protocols": "Http1",
        "Url": "http://*:80"
      }
    }
  },

  "Firmware": {
    "CdnBaseUrl": "https://cdn.openshock.app/firmware",
    "Storage": {
      "Type": "Local",
      "Local": {
        "BasePath": "./cdn-storage"
      }
    }
  },

  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Grafana.Loki",
      "OpenShock.RepositoryServer"
    ],
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.AspNetCore.Hosting.Diagnostics": "Warning",
        "Serilog.AspNetCore.RequestLoggingMiddleware": "Information",
        "OpenShock.RepositoryServer.AuthenticationHandlers": "Warning",
        "OpenShock": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss.fff}] [{Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithOpenShockEnricher"
    ]
  }
}
